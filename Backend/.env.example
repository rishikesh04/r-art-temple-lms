PORT=3000
NODE_ENV=development

MONGO_URI=mongodb://127.0.0.1:27017/r-art-temple-lms
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE=30d

CLIENT_URL=http://localhost:5173
JSON_BODY_LIMIT=200kb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=400
# Login/signup only (not /auth/me). Failed attempts count; successes do not.
AUTH_RATE_LIMIT_MAX=25
AUTH_RATE_LIMIT_WINDOW_MS=900000
ATTEMPT_SUBMIT_RATE_LIMIT_MAX=120

# Admin bootstrap credentials (required by your existing backend setup)
ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@example.com
ADMIN_PHONE=9999999999
ADMIN_PASSWORD=ChangeMe123!
